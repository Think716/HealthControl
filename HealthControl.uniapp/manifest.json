{
    "name": "HealthControl",
    "appid": "__UNI__HealthControl",
    "description": "健康管理系统",
    "versionName": "1.0.0",
    "versionCode": "100",
    "transformPx": false,

    "app-plus": {
        "usingComponents": true,
